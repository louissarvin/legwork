APP_PORT=3700
NODE_ENV=development
DATABASE_URL="postgresql://postgres:admin@localhost:5432/<db-name>?schema=public"
JWT_SECRET="your-jwt-secret-key-here"
JWT_EXPIRES_IN=7d

# WDK Configuration
WDK_SEED="your twelve word seed phrase for agent treasury"

# AI Provider (agent reasoning + photo verification)
# Primary: Anthropic Claude. Fallback: Groq Llama 4 Scout.
# Set at least one. If both set, Anthropic is primary with Groq as fallback.
ANTHROPIC_API_KEY="sk-ant-..."
GROQ_API_KEY=""
# Force provider: set to "groq" to skip Anthropic entirely
# AI_PROVIDER=""

# Network
CHAIN_NETWORK=sepolia

# Secret Manager
SECRET_PASSKEY="your-secret-passkey-for-seed-encryption"

# WDK Indexer API (register at https://wdk-api.tether.io/register)
WDK_INDEXER_API_KEY=""

# EAS (Ethereum Attestation Service)
EAS_SCHEMA_UID=""

# Pinata IPFS
PINATA_JWT=""
PINATA_GATEWAY=""