// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  walletAddress String   @unique
  nonce        String?   // For signature verification
  lastSignIn   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ErrorLog {
  id         String   @id @default(cuid())
  errorCode  String
  message    String
  statusCode Int
  stack      String?  @db.Text
  context    String?  @db.Text
  userId     String?
  method     String?
  path       String?
  userAgent  String?  @db.Text
  ip         String?
  createdAt  DateTime @default(now())

  @@index([errorCode])
  @@index([createdAt])
}

model Task {
  id                  String        @id @default(cuid())
  description         String
  category            String        // photo, delivery, check, data, mystery, event
  lat                 Float         // Primary target location (dropoff for delivery)
  lon                 Float
  address             String?
  radiusMeters        Int           @default(100)
  // Delivery: pickup location (separate from dropoff lat/lon)
  pickupLat           Float?
  pickupLon           Float?
  pickupAddress       String?
  pickupRadiusMeters  Int?
  // Event: minimum time worker must be present
  minDurationMinutes  Int?
  paymentAmount       String        // USDT base units as string (BigInt safe)
  escrowAccountIndex  Int
  escrowAddress       String
  escrowTxHash        String?
  status              String        @default("open") // open, accepted, submitted, verified, paid, expired, rejected
  deadline            DateTime
  workerId            String?
  worker              Worker?       @relation(fields: [workerId], references: [id])
  clientRequestId     String?       // Scenario B: which client request funded this task
  submissions         Submission[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([status])
  @@index([workerId])
  @@index([clientRequestId])
}

model Worker {
  id               String       @id @default(cuid())
  name             String?
  walletAddress    String?      @unique
  seedEncrypted    String?      @db.Text // Encrypted seed phrase
  skills           String?      // Comma-separated: "photo,delivery,data,check,mystery,event"
  bio              String?      // Short worker description
  availability     String       @default("available") // available, busy, offline
  locationLat      Float?       // Worker's general location (approximate)
  locationLon      Float?
  reputationScore  Float        @default(0)
  tasksCompleted   Int          @default(0)
  totalEarned      String       @default("0") // USDT base units
  tasks            Task[]
  submissions      Submission[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Submission {
  id                  String   @id @default(cuid())
  taskId              String
  task                Task     @relation(fields: [taskId], references: [id])
  workerId            String
  worker              Worker   @relation(fields: [workerId], references: [id])
  photoHash           String?  // SHA-256 hash of photo bytes (duplicate detection)
  photoUrl            String?
  photoIpfsHash       String?
  reportData          String?  @db.Text // Category-specific data (JSON): delivery proof, check status, counts, reports
  gpsLat              Float?
  gpsLon              Float?
  exifData            String?  @db.Text // JSON
  verificationScore   Float?
  verificationResult  String?  @db.Text // JSON
  status              String   @default("pending") // pending, approved, rejected, manual_review
  payoutTxHash        String?
  attestationUid      String?
  createdAt           DateTime @default(now())

  @@index([taskId])
  @@index([workerId])
  @@index([status])
  @@index([photoHash])
}

model AgentLog {
  id        String   @id @default(cuid())
  action    String   // think, decide, execute, observe, error
  details   String   @db.Text // JSON
  txHash    String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
}

model Treasury {
  id            String   @id @default(cuid())
  chain         String
  balance       String   @default("0") // USDT base units
  aaveSupplied  String   @default("0")
  lastChecked   DateTime?
  updatedAt     DateTime @updatedAt

  @@unique([chain])
}

// Scenario B: External clients who fund the agent to create tasks
model Client {
  id              String          @id @default(cuid())
  walletAddress   String          @unique
  name            String?
  balance         String          @default("0") // Deposited USDT in base units
  totalDeposited  String          @default("0")
  totalSpent      String          @default("0")
  requests        ClientRequest[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ClientRequest {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id])
  description     String   // "Photograph 20 storefronts in Manhattan"
  category        String   // photo, delivery, check, data, mystery, event
  targetLat       Float?   // Center of task area
  targetLon       Float?
  targetAddress   String?
  budget          String   // Total USDT budget in base units
  pricePerTask    String?  // Agent-calculated price per task (set during fulfillment)
  maxPricePerTask String?  // Max USDT per task (client constraint)
  tasksRequested  Int      @default(1) // How many tasks to create
  tasksCreated    Int      @default(0)
  tasksCompleted  Int      @default(0)
  status          String   @default("pending") // pending, active, completed, cancelled, insufficient_funds
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId])
  @@index([status])
}
